MODEL=o4-mini
# OpenRouter: ustaw tutaj albo w Telegramie: /jarvis-set-openrouter-key (zapis w jarvis_runtime_secrets.json przy danych — w Dockerze /app/data, trwały).
OPENROUTER_API_KEY=
# 1 = append ~USD cost after token footer from GET https://openrouter.ai/api/v1/models (1 h cache). 0 = off.
OPENROUTER_SHOW_COST_ESTIMATE=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
# After restart: startup message goes to TELEGRAM_ALLOWED_CHAT_IDS; if empty, to chat_ids stored in session_paths.json (recent chats).
# After bot restart: send startup text to TELEGRAM_ALLOWED_CHAT_IDS chats and (by default) clear their conversation memory.
TELEGRAM_NOTIFY_ON_START=1
TELEGRAM_CLEAR_SESSION_ON_START=1
# Optional custom one-line startup text (empty = built-in default in English).
# TELEGRAM_STARTUP_MESSAGE=Hi, I am back.
TELEGRAM_POLLING_TIMEOUT_SEC=25
# Trwały katalog: audyt, pamięć rozmów, cache MSAL, microsoft_agent_settings.json, jarvis_runtime_secrets.json.
# Docker: zostaw /app/data/… (volumen). Instalacja bez Dockera: np. /home/user/jarvis1net/logs/audit.jsonl
AUDIT_LOG_PATH=/app/data/audit.jsonl

# MCP: stdio (default) = lokalny proces Node `mcp-jarvis1net`. HTTP = stary serwer z kluczem API.
MCP_MODE=stdio
MCP_STDIO_COMMAND=node
# JSON array — ścieżka do dist/index.js z pakietu mcp-jarvis1net (np. Docker: /opt/mcp-jarvis1net/dist/index.js).
MCP_STDIO_ARGS=["/opt/mcp-jarvis1net/dist/index.js"]
# Alternatywa do MCP_STDIO_ARGS: jedna ścieżka do skryptu JS.
# MCP_STDIO_NODE_SCRIPT=/opt/mcp-jarvis1net/dist/index.js
# Katalogi widoczne dla narzędzi fs_* w procesie MCP (oddziel przecinkiem).
MCP_ALLOWED_ROOTS=/app/data

# Tryb HTTP (MCP_MODE=http): URL serwera i klucz Bearer.
MCP_SERVER_URL=https://mcp.jarvis1.net
MCP_API_KEY=
MCP_TIMEOUT_SEC=15
MCP_MAX_TOOL_ROUNDS=18
# Max length of one tool JSON result in model context (Graph). Default 40k — mail lists with $select=id fit more ids.
MCP_TOOL_RESULT_MAX_CHARS=40000
# Lower cap only for microsoft_* tools (fewer tokens in Graph loops). Cannot exceed MCP_TOOL_RESULT_MAX_CHARS.
MCP_MICROSOFT_TOOL_RESULT_MAX_CHARS=12000
# Model max_tokens in chat+tools mode (avoids empty replies on long tool_calls).
MCP_CHAT_COMPLETION_MAX_TOKENS=10240
SESSION_CONTEXT_PATH=

# IANA timezone for model replies (convert mail/calendar from Graph UTC). E.g. Europe/Warsaw. Empty = no conversion rule.
DISPLAY_TIMEZONE=

# Microsoft Graph (optional): either a static token OR device-code login via /microsoft-login (needs MICROSOFT_CLIENT_ID).
MICROSOFT_GRAPH_ACCESS_TOKEN=
# Application (client) ID — public client, "Allow public client flows" = Yes in Azure. No client secret on the agent for device flow.
# Alternatively in Telegram: /microsoft-set-client <UUID> (saved to microsoft_agent_settings.json next to logs).
MICROSOFT_CLIENT_ID=
# Personal @outlook.com: consumers (default) + Azure redirect …/consumers/oauth2/nativeclient. Work/school: organizations. common only if you truly need MSA+AAD in one app.
MICROSOFT_TENANT_ID=consumers
# Space- or comma-separated delegated scopes (must match API permissions + admin consent if required).
MICROSOFT_GRAPH_SCOPES=User.Read Mail.ReadWrite Mail.Send Calendars.ReadWrite Files.ReadWrite.All
# Where MSAL stores tokens after /microsoft-login (default: next to audit log dir).
MICROSOFT_TOKEN_CACHE_PATH=

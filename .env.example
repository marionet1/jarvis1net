MODEL=o4-mini
OPENROUTER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
# Po restarcie: powitanie idzie na TELEGRAM_ALLOWED_CHAT_IDS; jeśli puste — na chat_id zapisane w session_paths.json (ostatnie rozmowy).
# Po restarcie bota: wyślij powitanie na czaty z TELEGRAM_ALLOWED_CHAT_IDS i (domyślnie) wyczyść im pamięć rozmowy.
TELEGRAM_NOTIFY_ON_START=1
TELEGRAM_CLEAR_SESSION_ON_START=1
# Opcjonalnie własna jednolinijkowa treść powitania (puste = domyślna po polsku).
# TELEGRAM_STARTUP_MESSAGE=Hej, jestem z powrotem.
TELEGRAM_POLLING_TIMEOUT_SEC=25
AUDIT_LOG_PATH=/home/jump/jarvis1net/logs/audit.jsonl
MCP_SERVER_URL=https://mcp.jarvis1.net
MCP_API_KEY=
MCP_TIMEOUT_SEC=15
MCP_MAX_TOOL_ROUNDS=18
# Maks. długość JSON jednego wyniku narzędzia w kontekście modelu (Graph). Domyślnie 40k — listy maili z $select=id mieszczą więcej id.
MCP_TOOL_RESULT_MAX_CHARS=40000
# Niższy limit tylko dla narzędzi microsoft_* (mniej tokenów w pętli Graph). Nie może być wyższy niż MCP_TOOL_RESULT_MAX_CHARS.
MCP_MICROSOFT_TOOL_RESULT_MAX_CHARS=12000
# max_tokens odpowiedzi modelu w trybie chat+narzędzia (unikaj pustej odpowiedzi przy długich tool_calls).
MCP_CHAT_COMPLETION_MAX_TOKENS=10240
SESSION_CONTEXT_PATH=

# Microsoft Graph (optional): either a static token OR device-code login via /microsoft-login (needs MICROSOFT_CLIENT_ID).
MICROSOFT_GRAPH_ACCESS_TOKEN=
# Application (client) ID — public client, "Allow public client flows" = Yes in Azure. No client secret on the agent for device flow.
# Możesz zamiast tego wpisać w Telegramie: /microsoft-set-client <UUID> (zapis do microsoft_agent_settings.json obok logów).
MICROSOFT_CLIENT_ID=
# Dla kont służbowych: organizations (+ redirect …/organizations/oauth2/nativeclient). Dla wyłącznie @outlook.com: consumers. common tylko gdy naprawdę potrzebujesz MSA+AAD w jednej aplikacji.
MICROSOFT_TENANT_ID=organizations
# Space- or comma-separated delegated scopes (must match API permissions + admin consent if required).
MICROSOFT_GRAPH_SCOPES=User.Read Mail.ReadWrite Mail.Send Calendars.ReadWrite Files.ReadWrite.All
# Where MSAL stores tokens after /microsoft-login (default: next to audit log dir).
MICROSOFT_TOKEN_CACHE_PATH=
